{{define "50-coverage.tmpl"}}
{{with .Coverage}}
<section class="context annex">
  <h3>Coverage stamp</h3>
  <dl>
    <dt>Window</dt><dd>{{date .Window.Since}} &rarr; {{date .Window.Until}}</dd>
    <dt>Token scope class</dt>
    <dd>
      {{if .TokenScopeClass}}<strong>{{.TokenScopeClass}}</strong>{{with .TokenScope}} &mdash; {{.}}{{end}}{{else if .TokenScope}}{{.TokenScope}}{{else}}<span class="muted">not reported</span>{{end}}
      <p class="muted">The access level of the API token used to collect this data. <strong>read-only</strong> tokens can only list public metadata; <strong>org-member</strong> tokens can also see private repositories within an organisation. A narrower scope gives evaluators higher confidence that the reported data has not been selectively filtered.</p>
    </dd>
    <dt>Repositories</dt>
    <dd>
      <p>{{len .Repos}} {{if eq (len .Repos) 1}}repository{{else}}repositories{{end}} covered{{with orgs .Repos}} in {{if eq (len .) 1}}org{{else}}orgs{{end}} {{range $i, $o := .}}{{if $i}}, {{end}}{{$o}}{{end}}{{end}}</p>
      <p class="muted">Individual repository names are not shown in the report — see the privacy notes for why.</p>
    </dd>
  </dl>
</section>
{{end}}

{{with .Verification}}
{{if .WorkflowRef}}
<section class="context annex">
  <h3>Verification details</h3>
  <dl>
    {{if .Provider}}<dt>Provider</dt><dd>{{.Provider}}</dd>{{end}}
    {{if .Repository}}<dt>Repository</dt><dd>{{.Repository}}</dd>{{end}}
    <dt>Workflow</dt><dd><code>{{.WorkflowRef}}</code></dd>
    {{if .RunURL}}<dt>Run</dt><dd><code>{{.RunURL}}</code></dd>{{end}}
  </dl>
  {{with .Attestation}}
  <p class="muted">Attestation ({{.Type}}): <code>{{.URL}}</code></p>
  <p>Verify the downloaded <code>report.json</code> with:</p>
  <pre><code>{{.VerifyCommand}}</code></pre>
  {{end}}
</section>
{{end}}
{{end}}
{{end}}
