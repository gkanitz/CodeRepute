{{define "20-verification.tmpl"}}
{{with .Verification}}
<section class="verification">
  <span class="badge {{.Status}}">{{.Status}}</span>
  {{if .Reason}}<span class="muted">{{.Reason}}</span>{{end}}
  {{if eq .Status "verified"}}
  <p class="muted">
    This report was produced by an automated CI run and its provenance has been
    attested. The numbers come directly from the platform API &mdash; they have
    not been edited after collection.
  </p>
  {{else}}
  <p class="muted">
    This report was produced locally and has not been independently verified.
    Treat it as a personal view rather than an auditable record.
  </p>
  {{end}}
</section>
{{end}}
{{end}}
