{{define "40-cadence.tmpl"}}
<hr class="annex-rule">
<h2 class="annex-title">Technical annex</h2>

{{with .Collaboration}}
<section class="annex-section">
  <h3>Collaboration &mdash; hard numbers</h3>
  <table class="annex-table">
    <thead><tr><th>Metric</th><th>Value</th></tr></thead>
    <tbody>
    {{with .PullRequests}}
      <tr><td>PRs authored</td><td>{{.Authored}}</td></tr>
      <tr><td>PRs merged</td><td>{{.Merged}}</td></tr>
    {{end}}
    {{with .ReviewsGiven}}
      <tr><td>Reviews given (total)</td><td>{{.Total}}</td></tr>
      <tr><td>Reviews given (approvals)</td><td>{{.Approvals}}</td></tr>
      <tr><td>Reviews given (changes requested)</td><td>{{.ChangesRequested}}</td></tr>
    {{end}}
    {{with .ReviewComments}}
      <tr><td>Review comments written</td><td>{{.Written}}</td></tr>
      <tr><td>Review comments received</td><td>{{.Received}}</td></tr>
    {{end}}
    {{with .TimeToMerge}}
      <tr><td>Time to merge (median hours)</td><td>{{hours .MedianHours}}</td></tr>
      <tr><td>Time to merge (merged PRs)</td><td>{{.Count}}</td></tr>
    {{end}}
    {{with .TimeToFirstReview}}
      <tr><td>Time to first review (median hours)</td><td>{{hours .MedianHours}}</td></tr>
      <tr><td>Time to first review (PRs)</td><td>{{.Count}}</td></tr>
    {{end}}
    {{with .Rework}}
      <tr><td>Rework rate</td><td>{{percent .Share}}</td></tr>
      <tr><td>Reworked PRs</td><td>{{.ReworkedPRs}}</td></tr>
      <tr><td>Reviewed PRs (denominator)</td><td>{{.ReviewedPRs}}</td></tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}

{{with .Cadence}}
<section class="context">
  <h3>Activity cadence</h3>
  <p>Volume and cadence are context only &mdash; they say nothing about quality. No score is derived from this data.</p>
  <p class="muted">An <strong>active day</strong> is any calendar day on which you opened a pull request, submitted a formal review (approve or request&nbsp;changes), or wrote an inline review comment on someone else&rsquo;s PR. Commits, merges, issue comments, and activity received on your own PRs are not counted. <strong>Contributions</strong> is the total number of those individual events across the window.</p>
  <dl>
    <dt>Active days</dt><dd>{{.ActiveDays}}</dd>
    <dt>Contributions</dt><dd>{{.Contributions}}</dd>
  </dl>

  {{/* Chart 2 — Contribution heatmap */}}
  {{with heatmapSVG $}}
  <div class="chart-wrap">{{.}}</div>
  {{end}}

  {{/* Cadence interpretation */}}
  {{if .ActiveDays}}
  <div class="interpretation">
    {{if ge .ActiveDays 120}}
    <p><strong>Consistent cadence.</strong> {{.ActiveDays}} active days across the coverage window with no extended gaps signals sustained, reliable engagement &mdash; not sprint-and-disappear contribution patterns. Evaluators weight consistent cadence heavily when assessing dependability.</p>
    {{else if ge .ActiveDays 60}}
    <p><strong>Regular but intermittent engagement.</strong> {{.ActiveDays}} active days shows meaningful involvement, with periods of lighter activity. This may reflect vacation, side projects, or a role with variable delivery cycles &mdash; context is needed to interpret gaps.</p>
    {{else}}
    <p><strong>Focused or episodic contribution.</strong> {{.ActiveDays}} active days in the coverage window indicates concentrated bursts of activity rather than consistent daily engagement. This can reflect deep-focus work, a handover period, or a secondary role on the team.</p>
    {{end}}
  </div>
  {{end}}

  {{if .Trend}}
  <table class="trend">
    <thead><tr><th>From</th><th>Until</th><th>Contributions</th></tr></thead>
    <tbody>
      {{range reverseTrend .Trend}}
      <tr><td>{{date .Start}}</td><td>{{date .End}}</td><td>{{total .Counts}}</td></tr>
      {{end}}
    </tbody>
  </table>
  {{end}}
</section>
{{end}}
{{end}}
