<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>CodeRepute report &mdash; {{.Report.Subject.Username}}</title>
<style>
  :root {
    --ink: #0F172A;
    --muted: #64748B;
    --line: #E2E8F0;
    --bg: #FFFFFF;
    --card-bg: #F8FAFC;
    --accent: #0EA5E9;
    --amber: #F59E0B;
    --indigo: #6366F1;
    --warn: #9a6700;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0 auto;
    max-width: 56rem;
    padding: 2rem 1.5rem 4rem;
    color: var(--ink);
    background: var(--bg);
    font: 15px/1.6 -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  /* ── Header ── */
  .report-header {
    border-bottom: 3px solid var(--ink);
    padding-bottom: 1.25rem;
    margin-bottom: 2rem;
  }
  .report-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 .2rem;
    letter-spacing: -.02em;
  }
  .report-header .subtitle {
    color: var(--muted);
    font-size: .85rem;
    margin: 0 0 .75rem;
  }
  .report-header .intro { margin: .5rem 0 0; font-size: .9rem; color: var(--muted); }

  /* ── KPI strip ── */
  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 1rem;
    margin: 0 0 2.5rem;
  }
  .kpi-card {
    background: var(--card-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1rem 1.1rem .9rem;
  }
  .kpi-card .kpi-value {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -.03em;
  }
  .kpi-card .kpi-label {
    display: block;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--muted);
    margin-top: .3rem;
    font-weight: 600;
  }

  /* ── Sections ── */
  .report-section {
    margin: 2.5rem 0;
  }
  .report-section h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 .35rem;
    padding-bottom: .4rem;
    border-bottom: 2px solid var(--line);
    letter-spacing: -.01em;
  }
  .section-intro {
    color: var(--muted);
    font-size: .88rem;
    margin: .5rem 0 1.25rem;
  }

  /* ── Chart wrapper ── */
  .chart-wrap {
    background: var(--card-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1.25rem 1.25rem .75rem;
    margin: 1rem 0;
    overflow-x: auto;
  }
  .chart-wrap svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Interpretation copy ── */
  .interpretation {
    background: var(--card-bg);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    padding: .75rem 1rem;
    margin: 1rem 0;
    font-size: .88rem;
  }
  .interpretation p { margin: 0 0 .5rem; }
  .interpretation p:last-child { margin: 0; }
  .interpretation strong { color: var(--ink); }

  /* ── Data summary ── */
  .data-summary {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem 2rem;
    margin: .75rem 0;
    font-size: .88rem;
  }
  .data-summary .ds-item { color: var(--muted); }
  .data-summary .ds-item strong { color: var(--ink); }

  /* ── Metric stories (within collab section) ── */
  .metric-story {
    margin: 1.5rem 0 2rem;
  }
  .metric-story h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 .6rem;
    color: var(--ink);
    border-left: 3px solid var(--accent);
    padding-left: .6rem;
  }
  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: .5rem 0 .75rem;
  }
  .stat .n {
    font-size: 1.9rem;
    font-weight: 800;
    display: block;
    letter-spacing: -.03em;
  }
  .stat .label { font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); font-weight: 600; }
  p.limit {
    border-left: 2px solid var(--line);
    padding-left: .75rem;
    font-size: .83rem;
    color: var(--muted);
    margin: .5rem 0;
  }

  /* ── Badges ── */
  .badge {
    display: inline-block;
    padding: .15rem .6rem;
    border-radius: 999px;
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .badge.unverified { background: #fff3cd; color: var(--warn); border: 1px solid #e6d8a8; }
  .badge.verified { background: #d9f2e3; color: #0f6f3f; border: 1px solid #b0dcc2; }

  /* ── Verification ── */
  section.verification { margin: .75rem 0 1.5rem; }

  /* ── Annex / context sections ── */
  hr.annex-rule { margin: 3rem 0 1rem; border: none; border-top: 2px solid var(--line); }
  h2.annex-title {
    font-size: .88rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  section.annex, section.annex-section {
    color: var(--muted);
    font-size: .85rem;
    margin-bottom: 1.25rem;
  }
  section.annex h3, section.annex-section h3 {
    font-size: .88rem;
    color: var(--muted);
    border-bottom: 1px dotted var(--line);
    padding-bottom: .2rem;
    margin-top: 1rem;
  }
  table.annex-table { border-collapse: collapse; width: 100%; margin: .5rem 0; }
  table.annex-table th, table.annex-table td {
    text-align: left;
    padding: .15rem .75rem .15rem 0;
    border-bottom: 1px solid var(--line);
    font-weight: 400;
    font-size: .83rem;
  }
  table.annex-table th { color: var(--muted); font-size: .78rem; }
  table.trend { border-collapse: collapse; margin: .5rem 0; }
  table.trend th, table.trend td {
    text-align: left;
    font-weight: 400;
    padding: .1rem 1.25rem .1rem 0;
    border-bottom: 1px solid var(--line);
  }
  dl { display: grid; grid-template-columns: max-content 1fr; gap: .25rem 1rem; margin: .5rem 0; }
  dt { color: var(--muted); }
  dd { margin: 0; }
  section.context { margin: 1rem 0; }
  pre, code { font-size: .82rem; }
  pre { background: var(--card-bg); border: 1px solid var(--line); border-radius: 4px; padding: .6rem .8rem; overflow-x: auto; }
  footer {
    margin-top: 3rem;
    border-top: 1px solid var(--line);
    padding-top: .75rem;
    color: var(--muted);
    font-size: .8rem;
  }
  .muted { color: var(--muted); }
</style>
</head>
<body>
{{.Body}}
<footer>
  Generated {{date .Report.GeneratedAt}} by CodeRepute &middot; report schema {{.Report.SchemaVersion}} &middot;
  built from API metadata only &mdash; no source code was read.
</footer>
</body>
</html>
